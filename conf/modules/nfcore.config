

process {
    withName: 'FASTP' {
        publishDir = [ 
            [
                mode: "copy",
                pattern: "*.json",
                path: { "${params.outdir}/preprocessing/fastp/${meta.id}/" },
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ],
            [
                mode: "copy",
                pattern: "*.html",
                path: { "${params.outdir}/preprocessing/fastp/${meta.id}/" },
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ],
            [
                pattern: "*.fastq.gz",
                path: { "${params.outdir}/preprocessing/fastp/${meta.id}/" },
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
            ]
        ]
    }
    withName: 'FASTQC' {
        publishDir = [
            mode: "copy",
            path: { "${params.outdir}/preprocessing/fastqc_raw/${meta.id}/" },
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: 'FASTQC2' {
        publishDir = [
            mode: "copy",
            path: { "${params.outdir}/preprocessing/fastqc_trimmed/${meta.id}/" },
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}


process {
  withName: 'GATK4_MARKDUPLICATES' {
    ext.prefix = { "${meta.id}.md" } 
    scratch = false
    time = '10h'
    publishDir = [
            mode: "copy",
            path: { "${params.outdir}/mapping/gatk4/${meta.id}/"},
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
  }
}

process {
  withName: 'BWAMEM2_MEM' {
        scratch = true
        ext.prefix = { "${meta.id}.${meta.lane}" }
        ext.args = { "-R \'@RG\\tID:${meta.id}.${meta.lane}\\tPU:${meta.lane}\\tSM:${meta.id}\\tDS:${fasta}\'" } 
  }
}

process {
  withName: 'BWAMEM2_MEM' {
        scratch = true
        ext.prefix = { "${meta.id}.merged" }
  }
}
